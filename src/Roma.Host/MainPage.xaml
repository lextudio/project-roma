<Page x:Class="Roma.Host.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:dock="using:AvalonDock"
      xmlns:themes="using:UnoDock.Themes.VS2013"
      xmlns:local="using:Roma.Host"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <themes:Vs2013LightTheme x:Key="Vs2013LightTheme" />

    <DataTemplate x:Key="TabPageTemplate">
      <local:DocTabContent />
    </DataTemplate>

    <!-- Tool-pane content: DataContext = RomaToolPaneModel; its Content is the ready-built WinUI element. -->
    <DataTemplate x:Key="AnchorablePaneTemplate">
      <ContentControl Content="{Binding Content}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      VerticalContentAlignment="Stretch" />
    </DataTemplate>

    <!-- DataTemplate for assembly tree nodes. DataContext = TreeViewNode; Content = TreeNodeViewModel -->
    <DataTemplate x:Key="AssemblyTreeItemTemplate">
      <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
        <Grid Width="16" Height="16"
              Visibility="{Binding Content.HasIcon}">
          <Image Width="16" Height="16"
                 Source="{Binding Content.BaseIcon}" />
          <Image Width="16" Height="16"
                 Source="{Binding Content.OverlayIcon}"
                 Visibility="{Binding Content.OverlayVisibility}" />
        </Grid>
        <TextBlock Text="{Binding Content.Text}"
                   Foreground="{Binding Content.Foreground}"
                   VerticalAlignment="Center" />
      </StackPanel>
    </DataTemplate>
  </Page.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <!-- Menu bar -->
      <RowDefinition Height="Auto" />
      <!-- Toolbar -->
      <RowDefinition Height="Auto" />
      <!-- Update notification banner (collapsed unless an update is available / checked) -->
      <RowDefinition Height="Auto" />
      <!-- DockingManager -->
      <RowDefinition Height="*" />
      <!-- Status bar -->
      <RowDefinition Height="22" />
    </Grid.RowDefinitions>

    <!-- ── Menu bar (mirrors WPF ILSpy menu structure) ──────── -->
    <MenuBar Grid.Row="0"
             x:Name="_menuBar"
             Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

      <!-- File menu: Open category | Save category | Remove category | Exit -->
      <MenuBarItem Title="File">
        <MenuFlyoutItem Text="Open..." Click="OnMenuOpen">
          <MenuFlyoutItem.Icon><ImageIcon Source="{local:ILSpyIcon File=open.svg}" /></MenuFlyoutItem.Icon>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Open from GAC..." Click="OnMenuOpenFromGac">
          <MenuFlyoutItem.Icon><ImageIcon Source="{local:ILSpyIcon File=assembly_list_gac.svg}" /></MenuFlyoutItem.Icon>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Manage Assembly Lists..." Click="OnMenuManageAssemblyLists">
          <MenuFlyoutItem.Icon><ImageIcon Source="{local:ILSpyIcon File=assembly_list.svg}" /></MenuFlyoutItem.Icon>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Reload All" Click="OnMenuReloadAll">
          <MenuFlyoutItem.Icon><ImageIcon Source="{local:ILSpyIcon File=refresh.svg}" /></MenuFlyoutItem.Icon>
        </MenuFlyoutItem>
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Save Code..." Click="OnMenuSaveCode">
          <MenuFlyoutItem.Icon><ImageIcon Source="{local:ILSpyIcon File=save.svg}" /></MenuFlyoutItem.Icon>
        </MenuFlyoutItem>
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Remove Assemblies with Load Errors" Click="OnMenuRemoveAssembliesWithErrors" />
        <MenuFlyoutItem Text="Clear Assembly List"                Click="OnMenuClearAssemblyList" />
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Exit" Click="OnMenuExit" />
      </MenuBarItem>

      <!-- View menu: API visibility | Theme | UI Language | Options -->
      <MenuBarItem Title="View">
        <ToggleMenuFlyoutItem x:Name="_menuShowPublicOnly"
                              Text="Show public types and members only"
                              Click="OnMenuApiVisPublicOnly" />
        <ToggleMenuFlyoutItem x:Name="_menuShowInternal"
                              Text="Show internal types and members"
                              Click="OnMenuApiVisPublicAndInternal" />
        <ToggleMenuFlyoutItem x:Name="_menuShowAllMembers"
                              Text="Show all types and members"
                              IsChecked="True"
                              Click="OnMenuApiVisAll" />
        <MenuFlyoutSeparator />
        <MenuFlyoutSubItem x:Name="_themeMenu" Text="Theme" />
        <MenuFlyoutSubItem x:Name="_uiLanguageMenu" Text="UI Language" />
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Sort Assembly List by Name" Click="OnSortAssemblyList">
          <MenuFlyoutItem.Icon><ImageIcon Source="{local:ILSpyIcon File=sort.svg}" /></MenuFlyoutItem.Icon>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Collapse Tree Nodes" Click="OnCollapseAll">
          <MenuFlyoutItem.Icon><ImageIcon Source="{local:ILSpyIcon File=collapse_all.svg}" /></MenuFlyoutItem.Icon>
        </MenuFlyoutItem>
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Options..." Click="OnMenuOptions" />
      </MenuBarItem>

      <!--
        Window menu — order mirrors ILSpy InitWindowMenu():
          MEF commands (Close All, Reset Layout)
          separator
          tool panes (Assemblies, Search, Analyze, Debug Steps)
          separator
          open tab pages
      -->
      <MenuBarItem Title="Window">
        <MenuFlyoutItem Text="Close All Documents" Click="OnMenuCloseAllDocuments" />
        <MenuFlyoutItem Text="Reset Layout"        Click="OnMenuResetLayout" />
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Assemblies"    Click="OnMenuShowAssembliesPane" />
        <MenuFlyoutItem x:Name="_menuShowSearchPane"
                        Text="Search"
                        Click="OnMenuShowSearchPane">
          <MenuFlyoutItem.Icon><ImageIcon Source="{local:ILSpyIcon File=search.svg}" /></MenuFlyoutItem.Icon>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Analyze"       Click="OnMenuShowAnalyzerPane" />
        <MenuFlyoutItem Text="Debug Steps"   Click="OnMenuShowDebugStepsPane" />
        <MenuFlyoutSeparator />
        <MenuFlyoutItem x:Name="_menuTabCode" Text="Code" Click="OnMenuShowCodeTab" />
      </MenuBarItem>

      <!-- Help menu: Check for Updates | About -->
      <MenuBarItem Title="Help">
        <MenuFlyoutItem Text="Check for Updates..." Click="OnMenuCheckForUpdates" />
        <MenuFlyoutItem Text="About"                Click="OnMenuAbout" />
      </MenuBarItem>

    </MenuBar>

    <!-- ── Toolbar ──────────────────────────────────────────── -->
    <!--
      Layout mirrors ILSpy MainWindow toolbar:
        Content area (left):  assembly-list combo + manage btn | API-vis toggles | language combos
        Primary commands (right): Open, Reload | Search | Back, Forward
    -->
    <!--
      Toolbar order mirrors ILSpy MainToolBar (left to right):
        Back | Forward | sep | Open | Reload | sep | AssemblyList combo + Manage | sep
        | ShowPublicOnly | ShowPrivateInternal | ShowAll | sep | Language | LangVersion
      Everything lives in CommandBar.Content so items flow left-to-right in correct order.
    -->
    <CommandBar Grid.Row="1"
                x:Name="_toolBar"
                DefaultLabelPosition="Collapsed"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Center">

      <CommandBar.Content>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="2" Margin="4,0">

          <!-- Navigation: Back / Forward (ILSpy 'Navigation' toolbar category) -->
          <Button x:Name="_navBackBtn"
                  Width="32" Height="32" Padding="0"
                  ToolTipService.ToolTip="Navigate Back"
                  Click="OnNavigateBack">
            <Image x:Name="_navBackIcon" Width="16" Height="16" Source="{local:ILSpyIcon File=back.svg}" />
          </Button>
          <Button x:Name="_navForwardBtn"
                  Width="32" Height="32" Padding="0"
                  ToolTipService.ToolTip="Navigate Forward"
                  Click="OnNavigateForward">
            <Image x:Name="_navForwardIcon" Width="16" Height="16" Source="{local:ILSpyIcon File=forward.svg}" />
          </Button>

          <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,6" />

          <!-- Open / Reload (ILSpy 'Open' toolbar category) -->
          <Button Width="32" Height="32" Padding="0"
                  ToolTipService.ToolTip="Open Assembly"
                  Click="OnOpenAssembly">
            <Image Width="16" Height="16" Source="{local:ILSpyIcon File=open.svg}" />
          </Button>
          <Button Width="32" Height="32" Padding="0"
                  ToolTipService.ToolTip="Reload All"
                  Click="OnReloadAll">
            <Image Width="16" Height="16" Source="{local:ILSpyIcon File=refresh.svg}" />
          </Button>

          <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,6" />

          <!-- Assembly list selector + manage button -->
          <ComboBox x:Name="_assemblyListCombo"
                    PlaceholderText="Assembly list"
                    Width="160"
                    SelectionChanged="OnAssemblyListSelectionChanged" />
          <Button x:Name="_manageAssemblyListsBtn"
                  Width="32" Height="32" Padding="0"
                  ToolTipService.ToolTip="Manage Assembly Lists"
                  Click="OnManageAssemblyLists">
            <Image Width="16" Height="16" Source="{local:ILSpyIcon File=assembly_list.svg}" />
          </Button>

          <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,6" />

          <!-- API visibility: ShowPublicOnly | ShowPrivateInternal | ShowAll -->
          <ToggleButton x:Name="_apiVisPublicOnly"
                        Width="32" Height="32" Padding="0"
                        ToolTipService.ToolTip="Show public types and members only"
                        Click="OnApiVisPublicOnly">
            <Image Width="16" Height="16" Source="{local:ILSpyIcon File=show_public_only.svg}" />
          </ToggleButton>
          <ToggleButton x:Name="_apiVisPublicAndInternal"
                        Width="32" Height="32" Padding="0"
                        ToolTipService.ToolTip="Show public and internal types and members"
                        Click="OnApiVisPublicAndInternal">
            <Image Width="16" Height="16" Source="{local:ILSpyIcon File=show_private_internal.svg}" />
          </ToggleButton>
          <ToggleButton x:Name="_apiVisAll"
                        Width="32" Height="32" Padding="0"
                        IsChecked="True"
                        ToolTipService.ToolTip="Show all types and members"
                        Click="OnApiVisAll">
            <Image Width="16" Height="16" Source="{local:ILSpyIcon File=show_all.svg}" />
          </ToggleButton>

          <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,6" />

          <!-- Language selector -->
          <ComboBox x:Name="_languageCombo"
                    PlaceholderText="Language"
                    DisplayMemberPath="Name"
                    Width="130"
                    SelectionChanged="OnLanguageSelectionChanged" />

          <!-- Language version (hidden until a versioned language is selected) -->
          <ComboBox x:Name="_languageVersionCombo"
                    PlaceholderText="Version"
                    DisplayMemberPath="DisplayName"
                    Width="110"
                    Visibility="Collapsed"
                    SelectionChanged="OnLanguageVersionSelectionChanged" />

          <Border Width="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,6" />

          <!-- View category: Sort assembly list | Collapse all tree nodes | Search -->
          <Button Width="32" Height="32" Padding="0"
                  ToolTipService.ToolTip="Sort Assembly List by Name"
                  Click="OnSortAssemblyList">
            <Image Width="16" Height="16" Source="{local:ILSpyIcon File=sort.svg}" />
          </Button>
          <Button Width="32" Height="32" Padding="0"
                  ToolTipService.ToolTip="Collapse All Tree Nodes"
                  Click="OnCollapseAll">
            <Image Width="16" Height="16" Source="{local:ILSpyIcon File=collapse_all.svg}" />
          </Button>
          <Button x:Name="_toolbarSearchButton"
                  Width="32" Height="32" Padding="0"
                  ToolTipService.ToolTip="Search (Ctrl+Shift+F)"
                  Click="OnSearch">
            <Image Width="16" Height="16" Source="{local:ILSpyIcon File=search.svg}" />
          </Button>

        </StackPanel>
      </CommandBar.Content>
    </CommandBar>

    <!-- ── Update notification banner (ILSpy UpdatePanel parity) ── -->
    <Border Grid.Row="2"
            x:Name="_updateBanner"
            Visibility="Collapsed"
            Background="{ThemeResource SystemControlBackgroundAccentBrush}"
            BorderThickness="0,0,0,1"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            Padding="8,4">
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock x:Name="_updateBannerMessage"
                   Foreground="White"
                   VerticalAlignment="Center" />
        <Button x:Name="_updateDownloadButton"
                Content="Download"
                Visibility="Collapsed"
                Click="OnUpdateBannerDownload" />
        <Button Content="Dismiss" Click="OnUpdateBannerClose" />
      </StackPanel>
    </Border>

    <!-- ── DockingManager ───────────────────────────────────── -->
    <dock:DockingManager Grid.Row="3"
                         x:Name="DockManager"
                         Layout="{x:Bind DockLayout, Mode=OneWay}"
                         Theme="{StaticResource Vs2013LightTheme}" />

    <!-- ── Status bar ───────────────────────────────────────── -->
    <Border Grid.Row="4"
            Background="#FF007ACC"
            Padding="8,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock VerticalAlignment="Center"
                   Foreground="White"
                   FontSize="11"
                   Text="{x:Bind FooterStatus, Mode=OneWay}" />
        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   Foreground="White"
                   FontSize="11"
                   Text="{x:Bind CandidateFooter, Mode=OneWay}" />
      </Grid>
    </Border>
  </Grid>
</Page>
