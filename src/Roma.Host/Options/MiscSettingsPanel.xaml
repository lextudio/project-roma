<UserControl
    x:Class="Roma.Host.Options.MiscSettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <StackPanel Margin="4" Spacing="4">
    <TextBlock Text="Misc" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,4"/>
    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="4" Padding="12,8">
      <StackPanel Spacing="6">
        <CheckBox Content="Allow multiple instances"
                  IsChecked="{Binding Settings.AllowMultipleInstances, Mode=TwoWay}" />
        <CheckBox Content="Load assemblies that were loaded in the last instance."
                  IsChecked="{Binding Settings.LoadPreviousAssemblies, Mode=TwoWay}" />
        <CheckBox x:Name="_hideMacOSAppMenu"
                  Content="Hide in-app main menu on macOS"
                  Checked="OnHideMacOSAppMenuChanged"
                  Unchecked="OnHideMacOSAppMenuChanged" />
        <CheckBox x:Name="_recentFontsEnabled"
                  Content="Remember recently used fonts"
                  Checked="OnRecentFontsChanged"
                  Unchecked="OnRecentFontsChanged" />
      </StackPanel>
    </Border>

    <TextBlock Text="Terminal" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,4"/>
    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="4" Padding="12,8">
      <StackPanel Spacing="6">
        <TextBlock Text="Preferred terminal for &quot;Open command line here&quot;:"
                   TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        <ComboBox x:Name="_terminalCombo"
                  MinWidth="220" HorizontalAlignment="Left"
                  SelectionChanged="OnTerminalChanged" />
        <TextBox x:Name="_customTerminalPath"
                 PlaceholderText="Path to custom terminal executable"
                 Visibility="Collapsed"
                 TextChanged="OnCustomTerminalPathChanged" />
      </StackPanel>
    </Border>

    <TextBlock Text="Shell Integration" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,8,0,4"/>
    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="4" Padding="12,8">
      <StackPanel Spacing="8">
        <TextBlock Text="{Binding ShellIntegrationDescription}"
                   TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        <Button x:Name="_shellIntegrationBtn"
                Content="{Binding AddRemoveShellIntegrationText}"
                IsEnabled="{Binding IsShellIntegrationSupported}"
                Click="OnShellIntegrationClick" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
