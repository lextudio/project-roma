<UserControl
    x:Class="Roma.Host.Options.DecompilerSettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="using:CommunityToolkit.WinUI.Controls">

  <primitives:DockPanel>
    <TextBlock primitives:DockPanel.Dock="Top"
               Text="Enable or disable individual decompiler features. Changes take effect after re-decompiling."
               TextWrapping="Wrap"
               Margin="4,4,4,8"
               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Settings}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Expander IsExpanded="True"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Left"
                      Margin="0,2">
              <Expander.Header>
                <CheckBox IsChecked="{Binding AreAllItemsChecked, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          FontSize="14"
                          FontWeight="SemiBold">
                  <CheckBox.Content>
                    <TextBlock Text="{Binding Category}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextWrapping="NoWrap" />
                  </CheckBox.Content>
                </CheckBox>
              </Expander.Header>
              <ItemsControl ItemsSource="{Binding Settings}"
                            Margin="20,2,0,4"
                            HorizontalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                              HorizontalAlignment="Left"
                              Margin="0,1"
                              ToolTipService.ToolTip="{Binding Description}">
                      <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                    </CheckBox>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Expander>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </primitives:DockPanel>
</UserControl>
