<ContentDialog
    x:Class="Roma.Host.Options.OptionsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Options"
    PrimaryButtonText="OK"
    CloseButtonText="Cancel"
    PrimaryButtonClick="OnPrimaryButtonClick">

  <ContentDialog.Resources>
    <!-- Override ContentDialog's default 548 px max-width cap -->
    <x:Double x:Key="ContentDialogMaxWidth">1000</x:Double>
    <x:Double x:Key="ContentDialogMinWidth">860</x:Double>
  </ContentDialog.Resources>

  <Grid Width="820" Height="520">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="180" />
      <ColumnDefinition Width="1" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Panel selector -->
    <ListView x:Name="_panelList"
              Grid.Column="0"
              SelectionMode="Single"
              SelectionChanged="OnPanelSelectionChanged" />

    <!-- Separator -->
    <Rectangle Grid.Column="1"
               Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

    <!-- Content area -->
    <ContentPresenter x:Name="_contentArea"
                      Grid.Column="2"
                      Margin="12,4" />
  </Grid>
</ContentDialog>
