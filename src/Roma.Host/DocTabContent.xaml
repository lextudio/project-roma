<UserControl x:Class="Roma.Host.DocTabContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="using:ICSharpCode.AvalonEdit">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <avalonedit:TextEditor x:Name="PART_CodeEditor"
                               IsReadOnly="True"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch" />
        <Grid x:Name="PART_DecompilerHost"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch" />
        <ScrollViewer x:Name="PART_NodeHost"
                      Padding="12"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Visibility="Collapsed">
            <ContentPresenter x:Name="PART_NodeContent"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />
        </ScrollViewer>
    </Grid>
</UserControl>
